{<<"app">>,<<"ueberauth_apple">>}.
{<<"build_tools">>,[<<"mix">>]}.
{<<"description">>,<<"An Ueberauth strategy for Apple authentication.">>}.
{<<"elixir">>,<<"~> 1.10">>}.
{<<"files">>,
 [<<"lib">>,<<"lib/ueberauth_apple.ex">>,<<"lib/ueberauth">>,
  <<"lib/ueberauth/strategy">>,<<"lib/ueberauth/strategy/apple">>,
  <<"lib/ueberauth/strategy/apple/oauth.ex">>,
  <<"lib/ueberauth/strategy/apple/token.ex">>,
  <<"lib/ueberauth/strategy/apple.ex">>,<<"mix.exs">>,<<"README.md">>,
  <<"LICENSE">>]}.
{<<"licenses">>,[<<"MIT">>]}.
{<<"links">>,
 [{<<"GitHub">>,<<"https://github.com/ueberauth/ueberauth_apple">>}]}.
{<<"name">>,<<"ueberauth_apple">>}.
{<<"requirements">>,
 [[{<<"app">>,<<"httpoison">>},
   {<<"name">>,<<"httpoison">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 1.0 or ~> 2.0">>}],
  [{<<"app">>,<<"jose">>},
   {<<"name">>,<<"jose">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 1.0">>}],
  [{<<"app">>,<<"oauth2">>},
   {<<"name">>,<<"oauth2">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 2.0">>}],
  [{<<"app">>,<<"ueberauth">>},
   {<<"name">>,<<"ueberauth">>},
   {<<"optional">>,false},
   {<<"repository">>,<<"hexpm">>},
   {<<"requirement">>,<<"~> 0.10">>}]]}.
{<<"version">>,<<"0.6.1">>}.
