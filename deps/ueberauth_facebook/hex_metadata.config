  <<"lib/ueberauth/strategy">>,<<"lib/ueberauth/strategy/facebook.ex">>,
  <<"lib/ueberauth/strategy/facebook">>,
  <<"lib/ueberauth/strategy/facebook/oauth.ex">>,<<"mix.exs">>,
  <<"README.md">>,<<"CHANGELOG.md">>,<<"CONTRIBUTING.md">>,<<"LICENSE">>]}.
